# ====================================
# PORTFOLIO ENVIRONMENT VARIABLES
# ====================================

# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control!

# ========== SITE CONFIGURATION ==========
VITE_SITE_URL=https://moekyawaung.dev
VITE_SITE_NAME=Moe Kyaw Aung Portfolio
VITE_SITE_DESCRIPTION=Premium portfolio for Senior Android Developer & Full Stack Engineer

# ========== PERSONAL INFORMATION ==========
VITE_AUTHOR_NAME=Moe Kyaw Aung
VITE_AUTHOR_EMAIL=moekyawaung@programmer.net
VITE_AUTHOR_PHONE=+95 9 889 000 889
VITE_AUTHOR_LOCATION=Tachileik, Myanmar & Bangkok, Thailand

# ========== SOCIAL MEDIA ==========
VITE_GITHUB_USERNAME=Dev-moe-kyawaung
VITE_GITHUB_URL=https://github.com/Dev-moe-kyawaung
VITE_LINKEDIN_URL=https://www.linkedin.com/in/moe-kyaw-aung-2653093a1
VITE_YOUTUBE_URL=https://www.youtube.com/channel/UCuTXUguZb4xjeL2nX8WJGew
VITE_TWITTER_URL=https://twitter.com/your-handle
VITE_BLUESKY_URL=https://bsky.app/profile/moekyawaung96.bsky.social
VITE_INSTAGRAM_URL=https://instagram.com/your-handle
VITE_CODEPEN_URL=https://codepen.io/your-username
VITE_DRIBBBLE_URL=https://dribbble.com/your-username

# ========== ANALYTICS & TRACKING ==========
VITE_GA_ID=                              # Google Analytics ID (e.g., G-XXXXXXXXXX)
VITE_GTM_ID=                             # Google Tag Manager ID (optional)
VITE_SENTRY_DSN=                         # Sentry error tracking (optional)

# ========== API ENDPOINTS ==========
VITE_API_URL=https://api.example.com
VITE_GITHUB_API_TOKEN=                   # GitHub Personal Access Token (for API calls)

# ========== FORM SUBMISSIONS ==========
VITE_FORMSPREE_ID=                       # Formspree ID for contact form (e.g., f/xxxxx)
VITE_CONTACT_EMAIL=moekyawaung@programmer.net

# ========== VERCEL DEPLOYMENT ==========
VERCEL_ORG_ID=                           # From Vercel dashboard
VERCEL_PROJECT_ID=                       # From Vercel dashboard
VERCEL_TOKEN=                            # Vercel personal access token

# ========== NETLIFY DEPLOYMENT ==========
NETLIFY_AUTH_TOKEN=                      # Netlify personal access token
NETLIFY_SITE_ID=                         # Your Netlify site ID

# ========== FIREBASE (Optional) ==========
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ========== AWS (Optional) ==========
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=moe-portfolio

# ========== DOCKER ==========
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# ========== DEVELOPMENT ==========
NODE_ENV=production
DEBUG=false
VITE_LOG_LEVEL=warn                      # debug, info, warn, error

# ========== THEME & APPEARANCE ==========
VITE_DEFAULT_THEME=dark                  # light or dark
VITE_PRIMARY_COLOR=#00ff88
VITE_SECONDARY_COLOR=#ff006e
VITE_ACCENT_COLOR=#00d9ff

# ========== CUSTOMIZATION ==========
VITE_SHOW_BLOG=false                     # Enable blog section
VITE_SHOW_TESTIMONIALS=false             # Enable testimonials
VITE_SHOW_NEWSLETTER=false               # Enable newsletter signup
VITE_ENABLE_COMMENTS=false               # Enable comments

# ========== SECURITY ==========
VITE_CSP_ENABLED=true
VITE_SECURE_HEADERS=true

# ========== NOTES ==========
# 1. Never commit secrets to version control
# 2. Use strong, unique values for all tokens
# 3. Rotate tokens regularly
# 4. Use separate tokens for each environment
# 5. Keep this file in .gitignore
